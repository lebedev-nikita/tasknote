{
  "name": "@tasknote/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/api/trpc.ts",
      "default": "./src/api/trpc.ts"
    }
  },
  "scripts": {
    "dev": "  npx dotenv -e ../.env -- tsx --watch src/index.ts",
