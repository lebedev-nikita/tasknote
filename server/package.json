    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "2.0.6",
    "@trpc/server": "11.18.0",
    "hono": "4.12.27",
    "postgres": "^3.4.9",
    "superjson": "2.2.6",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "tsx": "4.22.4"
  }
}
