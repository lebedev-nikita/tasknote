{
  "name": "@tasknote/client",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json && expo export --platform web",
    "dev": "expo start",
    "dev:web": "expo start --web",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "56.0.15",
    "@tanstack/react-query": "5.101.1",
    "@trpc/client": "11.18.0",
    "@trpc/tanstack-react-query": "11.18.0",
    "expo": "56.0.12",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "5.7.0",
    "react-native-web": "0.21.2",
    "superjson": "2.2.6"
  },
  "devDependencies": {
    "@tasknote/server": "workspace:*",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3"
  }
}
