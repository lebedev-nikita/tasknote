{
  "name": "tasknote",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:client": "pnpm --filter @tasknote/client dev",
    "dev:client:web": "pnpm --filter @tasknote/client dev:web",
    "dev:expo": "pnpm --filter @tasknote/client dev",
    "dev:expo:web": "pnpm --filter @tasknote/client dev:web",
    "dev:server": "pnpm --filter @tasknote/server dev",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@lebedevna/prettier-plugin-sql": "^0.3.2",
    "@types/node": "26.0.1",
    "dotenv": "^17.4.2",
    "prettier": "^3.8.5",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
